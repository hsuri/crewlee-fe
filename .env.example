# Copy this to .env and fill in your values

PORT=3000

# Postgres connection string
# Local dev:  postgres://postgres:postgres@localhost:5432/mystartup
# Docker:     postgres://postgres:postgres@db:5432/mystartup
# Cloud Run:  set via deploy.sh (Cloud SQL socket URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mystartup

# Admin panel password
ADMIN_PASSWORD=change-me-in-production

# SMTP (optional — leave blank to use Ethereal test account in dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# Email addresses
EMAIL_FROM=hello@mystartup.com
NOTIFY_EMAIL=founder@mystartup.com
NOTIFY_EMAIL_2=
